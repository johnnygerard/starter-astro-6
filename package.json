    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
