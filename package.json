{
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.5",
    "clsx": "^2.1.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error",
      "version": "11"
    },
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": "24"
    }
  },
  "engines": {
    "node": "24",
    "npm": "11"
  },
  "name": "starter-astro-6",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build": "astro build && npm run check",
    "cf-typegen": "wrangler types",
    "check": "tsc --noEmit && astro check",
    "deploy": "npm run build && wrangler deploy",
    "dev": "astro dev",
    "docs": "astro docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "postlint": "echo '✅ Linting check successful.'",
    "preview": "npm run build && astro preview --port 4322",
    "pw": "playwright",
    "pw:test": "playwright test",
    "qa": "npm run format:check && npm run lint && npm test && npm run pw:test",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "toolbar:disable": "astro preferences disable devToolbar",
    "toolbar:enable": "astro preferences enable devToolbar",
    "wrangler": "wrangler"
  },
  "type": "module",
  "version": "0.0.0"
}
